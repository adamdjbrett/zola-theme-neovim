---
layout: layouts/base.njk
usePageStyles: true
---
<article class="h-entry">
  <h1 class="p-name">{{ title }}</h1>
  {% if date %}
  <p>
    <time class="dt-published" datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    <span class="p-author h-card">
      by <a class="p-name u-url" href="{{ metadata.author.url }}">{{ metadata.author.name }}</a>
    </span>
  </p>
  {% endif %}

  <div class="e-content">{{ content | safe }}</div>

  <nav aria-label="Post navigation">
    <ul class="section">
      {% if newerPost %}
      <li class="section"><a href="{{ newerPost.url }}">← {{ newerPost.data.title }}</a></li>
      {% endif %}
      {% if olderPost %}
      <li class="section"><a href="{{ olderPost.url }}">{{ olderPost.data.title }} →</a></li>
      {% endif %}
    </ul>
  </nav>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | json | safe }},
  "description": {{ (description or metadata.description) | json | safe }},
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ (updated or date) | isoDate }}",
  "author": {
    "@type": "Person",
    "name": {{ metadata.author.name | json | safe }}
  },
  "url": "{{ page.url | absoluteUrl(metadata.url) }}"
}
</script>
