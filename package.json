{
  "name": "neovim-theme-eleventy",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && rm -rf _site && eleventy --config=eleventy.config.js && npm run build:search",
    "start": "npm run build:css && eleventy --serve --config=eleventy.config.js --incremental",
    "build:css": "node scripts/build-css.mjs",
    "build:search": "pagefind --site _site --glob \"**/*.html\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "js-yaml": "^4.1.0",
    "luxon": "^3.5.0",
    "pagefind": "^1.3.0",
    "sass": "^1.86.3"
  }
}
