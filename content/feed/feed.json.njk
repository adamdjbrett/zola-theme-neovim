---
permalink: /feed/feed.json
eleventyExcludeFromCollections: true
---
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": {{ metadata.title | json | safe }},
  "home_page_url": "{{ '/' | absoluteUrl(metadata.url) }}",
  "feed_url": "{{ '/feed/feed.json' | absoluteUrl(metadata.url) }}",
  "description": {{ metadata.description | json | safe }},
  "authors": [
    {
      "name": {{ metadata.author.name | json | safe }},
      "url": "{{ metadata.author.url }}"
    }
  ],
  "items": [
    {% for post in collections.posts %}
    {
      "id": "{{ post.url | absoluteUrl(metadata.url) }}",
      "url": "{{ post.url | absoluteUrl(metadata.url) }}",
      "title": {{ post.data.title | json | safe }},
      "content_text": {{ (post.data.description or post.templateContent | striptags) | json | safe }},
      "date_published": "{{ post.date | isoDate }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
